# Production env for `pnpm run build`. The deploy workflow at
# .github/workflows/deploy.yml also sets these via the job env, which
# takes precedence; this file is the fallback for a local
# `pnpm run build` that bakes the same values.
#
# VITE_MERIDIAN_WS points the frontend at the Fly.io WebSocket origin.
# Update both this file and the deploy workflow if the Fly app name
# changes.
VITE_MERIDIAN_WS=wss://meridian-engine.fly.dev/ws
VITE_MERIDIAN_VERSION=0.1.0
VITE_MERIDIAN_COMPILER=g++ 14 trixie
VITE_MERIDIAN_FLAGS=-O3 -DNDEBUG -std=c++20
